<section class="landing__agents">
  <h2 class="landing__section-title">Built for any AI agent</h2>
  <p>
    CoPlan exposes a self-describing REST API. Point any AI agent — Amp, Claude Code, Cursor,
    your own — at <%= link_to "/agent-instructions", agent_instructions_path, class: "landing__inline-link" %>
    and it can create plans, apply edits, and leave review comments on your behalf.
    Agents authenticate with a bearer token from <strong>Settings &rarr; API&nbsp;Tokens</strong>.
  </p>
  <div class="landing__agents-url"
       data-controller="coplan--clipboard"
       data-coplan--clipboard-text-value="<%= agent_instructions_url %>">
    <code data-coplan--clipboard-target="source"><%= agent_instructions_url %></code>
    <button type="button"
            class="btn btn--secondary btn--sm copy-button"
            data-action="coplan--clipboard#copy"
            data-coplan--clipboard-target="button">Copy URL</button>
  </div>
</section>
