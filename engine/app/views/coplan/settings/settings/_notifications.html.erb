<% return unless CoPlan.configuration.web_push_configured? %>

<div class="card mb-md"
     data-controller="coplan--web-push-settings"
     data-coplan--web-push-settings-devices-url-value="<%= coplan.web_push_devices_path %>">
  <div class="settings-row">
    <div class="settings-row__main">
      <div class="settings-row__label">Browser notifications</div>
      <div class="settings-row__hint">
        Get a desktop notification when someone replies to your comments or mentions you.
        Enable this once per browser you want notifications on.
      </div>
    </div>
    <div class="settings-row__action">
      <button type="button"
              data-coplan--web-push-settings-target="enableButton"
              data-action="coplan--web-push-settings#enable"
              class="btn btn--primary btn--sm"
              hidden>
        Enable on this device
      </button>
      <button type="button"
              data-coplan--web-push-settings-target="disableButton"
              data-action="coplan--web-push-settings#disable"
              class="btn btn--secondary btn--sm"
              hidden>
        Disable on this device
      </button>
      <span data-coplan--web-push-settings-target="status" class="settings-row__status"></span>
    </div>
  </div>

  <%= render partial: "coplan/settings/settings/devices",
             locals: { web_push_subscriptions: @web_push_subscriptions } %>
</div>
