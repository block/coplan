<% content_for :title, "Agent Instructions — CoPlan" %>

<div class="agent-instructions">
  <header class="agent-instructions__header">
    <h1 class="agent-instructions__title">Connect your AI agent</h1>
    <p class="agent-instructions__lede">
      CoPlan's API is self-describing. Give your agent — Claude Code, Amp, Cursor, or your own —
      the URL below plus an API token, and it can create plans, apply edits, and respond to
      review comments on your behalf.
    </p>

    <div class="agent-instructions__url-card"
         data-controller="coplan--clipboard"
         data-coplan--clipboard-text-value="<%= @instructions_url %>">
      <div class="agent-instructions__url-label">Instructions URL — paste this into your agent</div>
      <div class="agent-instructions__url-row">
        <code class="agent-instructions__url" data-coplan--clipboard-target="source"><%= @instructions_url %></code>
        <button type="button"
                class="btn btn--primary copy-button"
                data-action="coplan--clipboard#copy"
                data-coplan--clipboard-target="button">Copy URL</button>
      </div>
    </div>

    <div class="agent-instructions__fetch">
      <p class="agent-instructions__fetch-hint">
        Agents fetch this same URL and receive the instructions as raw Markdown:
      </p>
      <pre class="agent-instructions__curl"><code>curl -s <%= @instructions_url %></code></pre>
      <p class="agent-instructions__fetch-hint">
        API tokens are created under <strong>Settings → API Tokens</strong>. You can also
        <%= link_to "view the raw markdown", agent_instructions_path(format: :md), class: "agent-instructions__raw-link" %>
        that agents see.
      </p>
    </div>
  </header>

  <article class="agent-instructions__doc">
    <%= render_markdown(@instructions_markdown, interactive: false) %>
  </article>
</div>
