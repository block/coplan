<%# Reusable "add" lightbox, built on the native Popover API like the search
    modal — the browser provides top-layer rendering, backdrop, Esc-to-close,
    and light-dismiss for free; the X in the corner closes it explicitly.

    Open it from any button carrying `popovertarget: "<id>"`. Render with a
    layout block for the body:

      render layout: "coplan/shared/add_modal",
        locals: { id: "add-reference-modal", title: "Add a reference" } do
          ...form...
        end
%>
<div id="<%= id %>" popover="auto" class="add-modal" aria-labelledby="<%= id %>-title">
  <div class="add-modal__header">
    <h3 class="add-modal__title" id="<%= id %>-title"><%= title %></h3>
    <button type="button" class="add-modal__close" popovertarget="<%= id %>" popovertargetaction="hide" aria-label="Close">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
    </button>
  </div>
  <div class="add-modal__body">
    <%= yield %>
  </div>
</div>
