<%# Copy-to-clipboard URL chip (see clipboard_controller.js).
    Locals:
      url          — the URL to display and copy (required)
      button_class — CSS classes for the copy button (optional) %>
<div class="copy-url"
     data-controller="coplan--clipboard"
     data-coplan--clipboard-text-value="<%= url %>">
  <code class="copy-url__value" data-coplan--clipboard-target="source"><%= url %></code>
  <button type="button"
          class="<%= local_assigns.fetch(:button_class, "btn btn--secondary btn--sm") %> copy-button"
          data-action="coplan--clipboard#copy"
          data-coplan--clipboard-target="button">Copy URL</button>
</div>
