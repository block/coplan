<%# The viewer's toolbar for this plan — the glass pill in the masthead's
    side column. Viewer-relative and policy-gated, so it renders only from
    request contexts: the show page, and the Turbo Stream responses to
    visibility/archive changes (which re-render it so menu labels track
    state). Broadcasts never touch it.

    Two relationships, two shapes:
      - can edit  → Edit (the primary action) + ⋯ menu (History, Move to
        folder…, visibility, Archive). Organizing your own library is a
        rare act, so it lives a level down — like Docs' move control.
      - reading   → Save/Saved (file it in your library to find it again)
        + ⋯ menu (History). %>
<% my_placement = local_assigns[:my_placement] %>
<% my_placement ||= plan.placements.includes(:library, :folder).detect { |p| p.library.writable_by?(current_user) } if current_user %>
<% can_edit = allowed_to?(plan, :edit_content?) %>
<div id="plan-toolbar" class="plan-actions" role="toolbar" aria-label="Plan actions">
  <% if current_user && !can_edit %>
    <button type="button"
            class="btn btn--ghost btn--sm plan-save<%= " plan-save--saved" if my_placement %>"
            data-action="coplan--folder-picker#open"
            data-move-url="<%= move_to_folder_plan_path(plan) %>"
            data-current-folder-id="<%= my_placement&.folder_id %>"
            data-saved="<%= my_placement.present? %>"
            data-plan-title="<%= plan.title %>"
            title="<%= my_placement ? "Saved in #{my_placement.folder.path} — click to move or remove" : "Save to your library to find it again" %>">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="<%= my_placement ? "currentColor" : "none" %>" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"/></svg>
      <span><%= my_placement ? "Saved" : "Save" %></span>
    </button>
  <% end %>
  <% if can_edit %>
    <%= link_to edit_content_plan_path(plan), class: "btn btn--ghost btn--sm",
          title: "Edit this plan — content, title, and tags" do %>
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z"/></svg>
      <span>Edit</span>
    <% end %>
  <% end %>
  <span data-controller="coplan--menu">
    <button type="button" class="btn btn--ghost btn--sm btn--icon"
            popovertarget="plan-menu" data-coplan--menu-target="trigger"
            aria-label="More actions" title="More actions">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true"><circle cx="5" cy="12" r="1.8"/><circle cx="12" cy="12" r="1.8"/><circle cx="19" cy="12" r="1.8"/></svg>
    </button>
    <div id="plan-menu" popover="auto" class="menu" data-coplan--menu-target="menu"
         data-action="toggle->coplan--menu#reposition" role="menu" aria-label="Plan actions menu">
      <%= link_to history_plan_path(plan), class: "menu__item", role: "menuitem" do %>
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M12 7v5l4 2"/></svg>
        <span>History</span>
      <% end %>
      <% if can_edit %>
        <button type="button" class="menu__item" role="menuitem"
                data-action="coplan--menu#close coplan--folder-picker#open"
                data-move-url="<%= move_to_folder_plan_path(plan) %>"
                data-current-folder-id="<%= my_placement&.folder_id %>"
                data-saved="<%= my_placement.present? %>"
                data-plan-title="<%= plan.title %>"
                data-picker-heading="Move to folder"
                data-remove-label="Remove from folder">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg>
          <span>Move to folder…</span>
        </button>
        <% if allowed_to?(plan, :publish?) %>
          <%= button_to publish_plan_path(plan), method: :patch, class: "menu__item", form_class: "menu__form", role: "menuitem" do %>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/><circle cx="12" cy="12" r="3"/></svg>
            <span>Share with everyone</span>
          <% end %>
        <% elsif allowed_to?(plan, :hide?) %>
          <%= button_to hide_plan_path(plan), method: :patch, class: "menu__item", form_class: "menu__form", role: "menuitem" do %>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/><circle cx="12" cy="12" r="3"/><line x1="3" y1="3" x2="21" y2="21"/></svg>
            <span>Make private</span>
          <% end %>
        <% end %>
        <% if allowed_to?(plan, :archive?) && !plan.archived? %>
          <div class="menu__separator" role="separator"></div>
          <%= button_to archive_plan_path(plan), method: :patch, class: "menu__item menu__item--danger", form_class: "menu__form", role: "menuitem" do %>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="5" x="2" y="3" rx="1"/><path d="M4 8v11a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8"/><path d="M10 12h4"/></svg>
            <span>Archive plan</span>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </span>
</div>
