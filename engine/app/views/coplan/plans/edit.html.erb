<div class="page-header">
  <h1>Edit: <%= @plan.title %></h1>
</div>

<%= form_with model: @plan, url: plan_path(@plan), method: :patch, class: "plan-form card" do |f| %>
  <div class="form-group">
    <%= f.label :title %>
    <%= f.text_field :title, required: true %>
  </div>

  <div class="form-group">
    <%= label_tag "plan_tag_field", "Tags" %>
    <%# Chips + a bare inline input; the hidden field keeps the API's
        comma-separated format so the update action is unchanged. %>
    <div class="tag-input" data-controller="coplan--tag-input" data-action="click->coplan--tag-input#focusInput">
      <div class="tag-input__chips" data-coplan--tag-input-target="chips">
        <input id="plan_tag_field" class="tag-input__field" list="tag-suggestions" autocomplete="off"
               placeholder="<%= @plan.tag_names.any? ? "Add tag…" : "Add a tag and press Enter…" %>"
               data-coplan--tag-input-target="input"
               data-action="keydown->coplan--tag-input#keydown blur->coplan--tag-input#commit change->coplan--tag-input#commit">
      </div>
      <%= hidden_field_tag "plan[tag_names]", @plan.tag_names.join(", "),
            id: "plan_tag_names", data: { "coplan--tag-input-target": "hidden" } %>
    </div>
    <datalist id="tag-suggestions">
      <% (@tag_suggestions || []).each do |name| %>
        <option value="<%= name %>"></option>
      <% end %>
    </datalist>
    <p class="text-sm text-muted">Reuse existing tags where possible — start typing for suggestions.</p>
  </div>

  <div class="plan-form__actions">
    <%= f.submit "Save Changes", class: "btn btn--primary" %>
    <%= link_to "Cancel", plan_path(@plan), class: "btn btn--secondary" %>
  </div>
<% end %>
