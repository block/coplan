<div class="workspace" data-controller="coplan--plan-groups coplan--folder-dnd">
  <%= render "coplan/plans/sidebar" %>

  <div class="workspace__main">
    <% active_filters = [] %>
    <% if @scope == "all" %>
      <%# Reachable from Home's tag links etc. — the sidebar no longer
          offers it, so show it as a clearable state, not a mode. %>
      <% active_filters << ["Everyone’s plans", workspace_path(scope: nil)] %>
    <% end %>
    <% if @folder %>
      <% active_filters << ["Folder: #{folder_path_for(@folder)}", workspace_path(folder: nil)] %>
    <% end %>
    <% if params[:tag].present? %>
      <% active_filters << ["Tag: #{params[:tag]}", workspace_path(tag: nil)] %>
    <% end %>
    <% if params[:plan_type].present? %>
      <% type_name = @plan_types&.find { |pt| pt.id == params[:plan_type] }&.name || "Type" %>
      <% active_filters << ["Type: #{type_name}", workspace_path(plan_type: nil)] %>
    <% end %>
    <% if @filter.present? %>
      <% filter_label = { "draft" => "Drafts", "published" => "Published", "archived" => "Archived" }.fetch(@filter) %>
      <% active_filters << [filter_label, workspace_path(filter: nil)] %>
    <% end %>

    <% if active_filters.any? %>
      <div class="active-filter workspace__filters">
        <% active_filters.each do |label, clear_path| %>
          <span class="workspace__filter-chip">
            <%= label %>
            <%= link_to "✕", clear_path, class: "workspace__filter-clear", aria: { label: "Clear #{label} filter" } %>
          </span>
        <% end %>
        <%= link_to "Clear all", plans_path(@scope == "mine" ? {} : { scope: @scope }), class: "active-filter__clear" %>
      </div>
    <% end %>

    <% if @attention_plans.present? %>
      <section class="attention" aria-label="Plans that need your attention">
        <h2 class="attention__heading">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
          Needs attention (<%= @attention_unread_counts.size %>)
        </h2>
        <ul class="attention__list">
          <% @attention_plans.each do |plan| %>
            <li class="attention__item">
              <%= link_to plan.title, plan_path(plan), class: "attention__link" %>
              <span class="attention__unread"><%= pluralize(@attention_unread_counts[plan.id].to_i, "unread comment") %></span>
            </li>
          <% end %>
        </ul>
        <% remaining = @attention_unread_counts.size - @attention_plans.size %>
        <% if remaining > 0 %>
          <p class="attention__more text-muted text-sm">
            + <%= pluralize(remaining, "more plan") %> with unread comments —
            <%= link_to "see notifications", notifications_path, class: "attention__link" %>
          </p>
        <% end %>
      </section>
    <% end %>

    <% if @groups %>
      <% if @recent_updates.present? %>
        <section class="recent-updates" aria-label="Changed since you last looked">
          <h2 class="recent-updates__heading">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M12 7v5l4 2"/></svg>
            Since you last looked
          </h2>
          <ul class="recent-updates__list">
            <% @recent_updates.each do |entry| %>
              <% plan = entry[:plan] %>
              <li class="recent-updates__item">
                <%= link_to plan.title, plan_path(plan), class: "recent-updates__link" %>
                <span class="recent-updates__badge recent-updates__badge--<%= entry[:badge].parameterize %>"><%= entry[:badge] %></span>
                <span class="recent-updates__meta text-muted">
                  <%= plan.created_by_user.name %> · <%= time_ago_in_words(plan.updated_at) %> ago
                </span>
              </li>
            <% end %>
          </ul>
        </section>
      <% end %>

      <% if @groups.any? %>
        <div class="plans-list">
          <% @groups.each do |group| %>
            <%= render "coplan/plans/plan_group", group: group %>
          <% end %>
        </div>
      <% else %>
        <div class="empty-state card">
          <% if params[:tag].present? || params[:plan_type].present? %>
            <p>No plans match the current filters.</p>
          <% elsif @scope == "mine" %>
            <p>You haven't created any plans yet. Plans are created via the API.</p>
          <% else %>
            <p>No plans yet. Plans are created via the API.</p>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <%# Flat mode: narrowed by ?filter= and/or ?folder= %>
      <% if @plans.any? %>
        <div class="plans-list">
          <%= render "coplan/plans/plan_page", plans: @plans,
                plan_unread_counts: @plan_unread_counts,
                page: @page,
                has_next_page: @has_next_page,
                group_key: "results",
                frame_filter: @filter,
                frame_folder: @folder&.id %>
        </div>
      <% else %>
        <div class="empty-state card">
          <% if @filter == "archived" %>
            <p>Nothing in the archive<%= " matches the current filters" if params[:tag].present? || params[:plan_type].present? || @folder %>.</p>
            <p class="text-muted text-sm">Archiving a plan hides it from lists and search without deleting it — it will show up here.</p>
          <% elsif @folder && @filter.blank? %>
            <p>No plans <%= "you can see " if @scope == "all" %>in <strong><%= folder_path_for(@folder) %></strong> yet.</p>
            <p class="text-muted text-sm">Drag a plan row onto this folder in the sidebar, or use a plan's row menu to move it here.</p>
          <% else %>
            <p>No <%= @filter %> plans match the current filters.</p>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
