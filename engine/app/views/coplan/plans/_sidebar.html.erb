<aside class="workspace__sidebar" aria-label="Plan filters">
  <div class="sidebar__section">
    <%# The folder tree IS your library; its public face lives on your
        profile, so there's no separate page to link to. %>
    <h3 class="sidebar__heading">Folders</h3>
    <ul class="folder-tree">
      <li class="folder-tree__node">
        <%= link_to workspace_path(folder: nil),
              class: "folder-tree__link #{'folder-tree__link--active' unless @folder}",
              data: {
                folder_id: "",
                action: "dragover->coplan--folder-dnd#dragOver dragleave->coplan--folder-dnd#dragLeave drop->coplan--folder-dnd#drop",
              } do %>
          <span class="folder-tree__name">Everything</span>
        <% end %>
      </li>
      <% @root_folders.each do |folder| %>
        <%= render "coplan/plans/folder_node", folder: folder %>
      <% end %>
    </ul>

    <% if @folders.empty? %>
      <p class="sidebar__hint text-muted text-sm">
        Folders keep related plans together — like a team folder with project subfolders.
      </p>
    <% end %>

    <%# Inline creation: opening the disclosure focuses the input; Enter
        creates a top-level folder, Esc closes. Nesting happens by dragging
        folders onto folders, so there's no parent picker. %>
    <details class="sidebar__new-folder" data-controller="coplan--new-folder"
             data-action="toggle->coplan--new-folder#focus">
      <summary class="sidebar__new-folder-toggle">+ New folder</summary>
      <%= form_with url: folders_path, scope: :folder, method: :post, class: "sidebar__new-folder-form" do |f| %>
        <%= f.text_field :name, placeholder: "Name, then Enter", required: true, maxlength: 100,
              class: "sidebar__new-folder-input",
              aria: { label: "Folder name" },
              data: { "coplan--new-folder-target": "input",
                      action: "keydown.esc->coplan--new-folder#close" } %>
      <% end %>
    </details>
  </div>

  <% if @top_tags.present? %>
    <div class="sidebar__section">
      <h3 class="sidebar__heading">Tags</h3>
      <ul class="sidebar__list">
        <% @top_tags.each do |name, count| %>
          <li>
            <%= link_to workspace_path(tag: params[:tag] == name ? nil : name),
                  class: "sidebar__item #{'sidebar__item--active' if params[:tag] == name}" do %>
              <span class="sidebar__item-label">#<%= name %></span>
              <span class="sidebar__count"><%= count %></span>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="sidebar__section">
    <%# No org-wide browsing here — the workspace is *your* stuff. Everyone
        else's work is discovered via Home, search, and people's profiles
        (?scope=all still works as a link target, e.g. from Home's tags). %>
    <h3 class="sidebar__heading">Filters</h3>
    <ul class="sidebar__list">
      <li>
        <%= link_to "Drafts", workspace_path(filter: @filter == "draft" ? nil : "draft"),
              class: "sidebar__item #{'sidebar__item--active' if @filter == 'draft'}" %>
      </li>
      <li>
        <%# Archived plans are hidden everywhere else — this is the explicit
            opt-in view. %>
        <%= link_to "Archived", workspace_path(filter: @filter == "archived" ? nil : "archived"),
              class: "sidebar__item sidebar__item--archived #{'sidebar__item--active' if @filter == 'archived'}" %>
      </li>
    </ul>
  </div>

  <% if @plan_types.present? %>
    <div class="sidebar__section">
      <h3 class="sidebar__heading">Types</h3>
      <ul class="sidebar__list">
        <% @plan_types.each do |pt| %>
          <li>
            <%= link_to pt.name,
                  workspace_path(plan_type: params[:plan_type] == pt.id ? nil : pt.id),
                  class: "sidebar__item #{'sidebar__item--active' if params[:plan_type] == pt.id}" %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</aside>
