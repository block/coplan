<aside class="workspace__sidebar" aria-label="Plan filters">
  <div class="sidebar__section">
    <h3 class="sidebar__heading">Folders
      <%# Same tree, but as the shareable read-only page others see. %>
      <%= link_to "View library →", my_library_path, class: "sidebar__heading-link", data: { turbo_frame: "_top" } %>
    </h3>
    <ul class="folder-tree">
      <li class="folder-tree__node">
        <%= link_to plans_path(params.permit(:scope, :filter, :plan_type, :tag)),
              class: "folder-tree__link #{'folder-tree__link--active' unless @folder}",
              data: {
                "coplan--folder-dnd-target": "folder",
                folder_id: "",
                action: "dragover->coplan--folder-dnd#dragOver dragleave->coplan--folder-dnd#dragLeave drop->coplan--folder-dnd#drop",
              } do %>
          <span class="folder-tree__name">All plans</span>
        <% end %>
      </li>
      <% @root_folders.each do |folder| %>
        <%= render "coplan/plans/folder_node", folder: folder %>
      <% end %>
    </ul>

    <% if @folders.empty? %>
      <p class="sidebar__hint text-muted text-sm">
        Folders keep related plans together — like a team folder with project subfolders.
      </p>
    <% end %>

    <details class="sidebar__new-folder">
      <summary class="sidebar__new-folder-toggle">+ New folder</summary>
      <%= form_with url: folders_path, scope: :folder, method: :post, class: "sidebar__new-folder-form" do |f| %>
        <%= f.text_field :name, placeholder: "Folder name", required: true, maxlength: 100, class: "sidebar__new-folder-input" %>
        <% parent_options = folder_select_options.reject { |_path, _id, depth| depth >= CoPlan::Folder::MAX_DEPTH } %>
        <% if parent_options.any? %>
          <%= f.select :parent_id,
                options_for_select([["Top level", ""]] + parent_options.map { |path, id, _| [path, id] }),
                {}, class: "sidebar__new-folder-select", aria: { label: "Parent folder" } %>
        <% end %>
        <%= f.submit "Create", class: "btn btn--sm" %>
      <% end %>
    </details>
  </div>

  <% if @top_tags.present? %>
    <div class="sidebar__section">
      <h3 class="sidebar__heading">Tags</h3>
      <ul class="sidebar__list">
        <% @top_tags.each do |name, count| %>
          <li>
            <%= link_to plans_path(params.permit(:scope, :filter, :plan_type, :folder).merge(tag: params[:tag] == name ? nil : name)),
                  class: "sidebar__item #{'sidebar__item--active' if params[:tag] == name}" do %>
              <span class="sidebar__item-label">#<%= name %></span>
              <span class="sidebar__count"><%= count %></span>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="sidebar__section">
    <h3 class="sidebar__heading">Filters</h3>
    <ul class="sidebar__list">
      <li>
        <%= link_to "My plans", plans_path(params.permit(:filter, :plan_type, :tag, :folder)),
              class: "sidebar__item #{'sidebar__item--active' if @scope == 'mine'}" %>
      </li>
      <li>
        <%= link_to "All plans", plans_path(params.permit(:filter, :plan_type, :tag, :folder).merge(scope: "all")),
              class: "sidebar__item #{'sidebar__item--active' if @scope == 'all'}" %>
      </li>
      <li>
        <%= link_to "Drafts", plans_path(params.permit(:scope, :plan_type, :tag, :folder).merge(filter: @filter == "draft" ? nil : "draft")),
              class: "sidebar__item #{'sidebar__item--active' if @filter == 'draft'}" %>
      </li>
      <li>
        <%# Archived plans are hidden everywhere else — this is the explicit
            opt-in view. %>
        <%= link_to "Archived", plans_path(params.permit(:scope, :plan_type, :tag, :folder).merge(filter: @filter == "archived" ? nil : "archived")),
              class: "sidebar__item sidebar__item--archived #{'sidebar__item--active' if @filter == 'archived'}" %>
      </li>
    </ul>
  </div>

  <% if @plan_types.present? %>
    <div class="sidebar__section">
      <h3 class="sidebar__heading">Types</h3>
      <ul class="sidebar__list">
        <% @plan_types.each do |pt| %>
          <li>
            <%= link_to pt.name,
                  plans_path(params.permit(:scope, :filter, :tag, :folder).merge(plan_type: params[:plan_type] == pt.id ? nil : pt.id)),
                  class: "sidebar__item #{'sidebar__item--active' if params[:plan_type] == pt.id}" %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</aside>
