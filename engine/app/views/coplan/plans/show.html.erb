<% content_for(:title, "#{@plan.title} — CoPlan") %>
<% content_for(:head) do %>
  <meta property="og:title" content="<%= @plan.title %>">
  <meta property="og:description" content="<%= plan_og_description(@plan) %>">
  <meta property="og:type" content="article">
  <meta property="og:site_name" content="CoPlan">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="<%= @plan.title %>">
  <meta name="twitter:description" content="<%= plan_og_description(@plan) %>">
<% end %>

<%= turbo_stream_from @plan %>

<div data-controller="coplan--presence" data-coplan--presence-plan-id-value="<%= @plan.id %>">
  <%= render partial: "coplan/plans/header", locals: { plan: @plan } %>
</div>

<% active_tab = %w[references history].include?(params[:tab]) ? params[:tab] : "content" %>
<div class="plan-tabs" data-controller="coplan--tabs">
  <div class="plan-tabs__nav">
    <a href="#tab-content" class="plan-tabs__tab<%= ' plan-tabs__tab--active' if active_tab == 'content' %>" data-coplan--tabs-target="tab" data-action="coplan--tabs#switch" data-tab-name="content">📄 Content</a>
    <a href="#tab-references" class="plan-tabs__tab<%= ' plan-tabs__tab--active' if active_tab == 'references' %>" data-coplan--tabs-target="tab" data-action="coplan--tabs#switch" data-tab-name="references">📎 References <span class="plan-tabs__count" id="references-count"><%= @references.size %></span></a>
    <a href="#tab-history" class="plan-tabs__tab<%= ' plan-tabs__tab--active' if active_tab == 'history' %>" data-coplan--tabs-target="tab" data-action="coplan--tabs#switch" data-tab-name="history">📜 History <span class="plan-tabs__count" id="history-count"><%= @plan.plan_versions.count %></span></a>
  </div>

  <div class="plan-tabs__panel card<%= ' plan-tabs__panel--hidden' unless active_tab == 'content' %>" id="tab-content" data-coplan--tabs-target="panel">
    <% if @plan.current_content.present? %>
      <div class="plan-layout" data-controller="coplan--text-selection coplan--content-nav coplan--checkbox" data-coplan--text-selection-plan-id-value="<%= @plan.id %>" data-coplan--text-selection-focus-thread-value="<%= params[:thread] %>" data-action="keydown.esc@document->coplan--text-selection#dismiss" data-coplan--checkbox-plan-id-value="<%= @plan.id %>" data-coplan--checkbox-revision-value="<%= @plan.current_revision %>" data-coplan--checkbox-toggle-url-value="<%= toggle_checkbox_plan_path(@plan) %>">
        <nav class="content-nav" data-coplan--content-nav-target="sidebar" aria-label="Document outline">
          <div class="content-nav__header">
            <span class="content-nav__title">Contents</span>
            <button type="button" class="content-nav__toggle" data-action="coplan--content-nav#toggle" data-coplan--content-nav-target="toggleBtn" aria-label="Hide table of contents" title="Toggle (])">✕</button>
          </div>
          <ul class="content-nav__list" data-coplan--content-nav-target="list"></ul>
        </nav>
        <button type="button" class="content-nav-show-btn" data-action="coplan--content-nav#toggle" data-coplan--content-nav-target="showBtn" title="Show table of contents (])">☰ <kbd>]</kbd></button>

        <div class="plan-layout__content" data-coplan--text-selection-target="content" data-coplan--content-nav-target="content">
          <%= render_markdown(@plan.current_content) %>

          <div class="comment-popover" data-coplan--text-selection-target="popover" style="display: none;">
            <button type="button" class="btn btn--primary btn--sm" data-action="coplan--text-selection#openCommentForm">
              💬 Comment
            </button>
          </div>

          <%= render partial: "coplan/comment_threads/new_comment_form", locals: { plan: @plan } %>
        </div>

        <div id="plan-threads" data-coplan--text-selection-target="threads">
          <% @threads.select(&:anchored?).each do |thread| %>
            <%= render partial: "coplan/comment_threads/thread_popover", locals: { thread: thread, plan: @plan, current_user: current_user } %>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="empty-state">
        <p>This plan has no content yet.</p>
      </div>
    <% end %>
  </div>

  <div class="plan-tabs__panel card<%= ' plan-tabs__panel--hidden' unless active_tab == 'references' %>" id="tab-references" data-coplan--tabs-target="panel">
    <%= render partial: "coplan/plans/references", locals: { references: @references, plan: @plan } %>
  </div>

  <div class="plan-tabs__panel card<%= ' plan-tabs__panel--hidden' unless active_tab == 'history' %>" id="tab-history" data-coplan--tabs-target="panel">
    <turbo-frame id="plan-history-frame" src="<%= history_plan_path(@plan) %>" loading="lazy">
      <div class="history-split__placeholder">
        <p class="text-muted">Loading…</p>
      </div>
    </turbo-frame>
  </div>
</div>

<% open_count = @threads.count(&:open?) %>
<% if @threads.any? %>
  <div class="comment-toolbar" data-controller="coplan--comment-nav" data-coplan--comment-nav-plan-id-value="<%= @plan.id %>">
    <span class="comment-toolbar__count">💬 <%= open_count %> open</span>
    <div class="comment-toolbar__nav">
      <button class="btn btn--secondary btn--sm" data-action="coplan--comment-nav#prev" title="Previous comment">↑</button>
      <span class="comment-toolbar__position" data-coplan--comment-nav-target="position"></span>
      <button class="btn btn--secondary btn--sm" data-action="coplan--comment-nav#next" title="Next comment">↓</button>
    </div>
    <label class="comment-toolbar__toggle">
      <input type="checkbox" data-action="coplan--comment-nav#toggleResolved" data-coplan--comment-nav-target="resolvedToggle">
      Show resolved (<%= @threads.count { |t| !t.open? } %>)
    </label>
  </div>
<% end %>
