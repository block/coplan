<% content_for(:title, "#{@plan.title} — CoPlan") %>
<% content_for(:head) do %>
  <meta property="og:title" content="<%= @plan.title %>">
  <meta property="og:description" content="<%= plan_og_description(@plan) %>">
  <meta property="og:type" content="article">
  <meta property="og:site_name" content="CoPlan">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="<%= @plan.title %>">
  <meta name="twitter:description" content="<%= plan_og_description(@plan) %>">
<% end %>

<%= turbo_stream_from @plan %>

<div data-controller="coplan--presence" data-coplan--presence-plan-id-value="<%= @plan.id %>">
  <%= render partial: "coplan/plans/header", locals: { plan: @plan } %>
</div>

<%# Owner affordances live outside the broadcast-replaced #plan-header so
    they can be policy-gated server-side (broadcast renders have no
    current_user). %>
<% if @plan.archived? %>
  <div class="plan-banner plan-banner--archived">
    <span class="plan-banner__text">This plan is archived — it stays readable at this URL but is hidden from lists and search results.</span>
    <% if allowed_to?(@plan, :unarchive?) %>
      <%= button_to "Restore", unarchive_plan_path(@plan), method: :patch, class: "btn btn--secondary btn--sm" %>
    <% end %>
  </div>
<% end %>
<%# One compact row: where the plan is filed (left) and what you can do to
    it (right). Lives outside the broadcast-replaced #plan-header — both
    sides are viewer-relative / policy-gated (broadcast renders have no
    current_user). %>
<div class="plan-meta-row">
  <%= render partial: "coplan/plans/shelves", locals: { plan: @plan, placements: @shelf_placements, my_folders: @my_folders } %>
  <% if allowed_to?(@plan, :update?) %>
    <div class="plan-actions">
      <% if allowed_to?(@plan, :publish?) %>
        <%# The one-way door out of private. "Share", not "publish" —
            visibility language, not a workflow stage. %>
        <%= button_to publish_plan_path(@plan),
              method: :patch,
              class: "btn btn--primary btn--sm",
              form: { data: { turbo_confirm: "This makes the plan visible to everyone in the org — it can't be made private again (you can archive it later). Continue?" } } do %>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/><circle cx="12" cy="12" r="3"/></svg>
          Share with everyone
        <% end %>
      <% end %>
      <%# One pen: the editor handles content, title, and tags together. %>
      <% if allowed_to?(@plan, :edit_content?) %>
        <%= link_to edit_content_plan_path(@plan), class: "btn btn--secondary btn--sm btn--icon",
              title: "Edit this plan — content, title, and tags", aria: { label: "Edit plan" } do %>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z"/></svg>
        <% end %>
      <% end %>
      <% if allowed_to?(@plan, :archive?) %>
        <%= button_to archive_plan_path(@plan), method: :patch,
              class: "btn btn--ghost btn--sm btn--icon", title: "Archive this plan",
              aria: { label: "Archive plan" }, form_class: "plan-actions__archive" do %>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="5" x="2" y="3" rx="1"/><path d="M4 8v11a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8"/><path d="M10 12h4"/></svg>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>

<% active_tab = %w[references attachments history].include?(params[:tab]) ? params[:tab] : "content" %>
<div class="plan-tabs" data-controller="coplan--tabs">
  <div class="plan-tabs__nav">
    <a href="#tab-content" class="plan-tabs__tab<%= ' plan-tabs__tab--active' if active_tab == 'content' %>" data-coplan--tabs-target="tab" data-action="coplan--tabs#switch" data-tab-name="content"><svg class="plan-tabs__icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg> Content</a>
    <a href="#tab-references" class="plan-tabs__tab<%= ' plan-tabs__tab--active' if active_tab == 'references' %>" data-coplan--tabs-target="tab" data-action="coplan--tabs#switch" data-tab-name="references"><svg class="plan-tabs__icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg> References <span class="plan-tabs__count" id="references-count"><%= @references.size %></span></a><button type="button" class="plan-tabs__add" title="Add a reference" aria-label="Add a reference" data-action="coplan--tabs#openAdd" data-panel-id="tab-references" data-tab-name="references" data-modal-id="add-reference-modal"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5v14"/></svg></button>
    <a href="#tab-attachments" class="plan-tabs__tab<%= ' plan-tabs__tab--active' if active_tab == 'attachments' %>" data-coplan--tabs-target="tab" data-action="coplan--tabs#switch" data-tab-name="attachments"><svg class="plan-tabs__icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m21.44 11.05-9.19 9.19a6 6 0 0 1-8.49-8.49l8.57-8.57A4 4 0 1 1 18 8.84l-8.59 8.57a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg> Attachments <span class="plan-tabs__count" id="attachments-count"><%= @attachments.size %></span></a><button type="button" class="plan-tabs__add" title="Add files" aria-label="Add files" data-action="coplan--tabs#openAdd" data-panel-id="tab-attachments" data-tab-name="attachments" data-modal-id="add-attachment-modal"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5v14"/></svg></button>
    <a href="#tab-history" class="plan-tabs__tab<%= ' plan-tabs__tab--active' if active_tab == 'history' %>" data-coplan--tabs-target="tab" data-action="coplan--tabs#switch" data-tab-name="history"><svg class="plan-tabs__icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M12 7v5l4 2"/></svg> History <span class="plan-tabs__count" id="history-count"><%= @plan.plan_versions.count + @plan.plan_events.count %></span></a>
  </div>

  <div class="plan-tabs__panel card<%= ' plan-tabs__panel--hidden' unless active_tab == 'content' %>" id="tab-content" data-coplan--tabs-target="panel">
    <% if @plan.current_content.present? %>
      <div class="plan-layout" data-controller="coplan--text-selection coplan--content-nav coplan--checkbox coplan--changed-sections" data-coplan--text-selection-focus-thread-value="<%= params[:thread] %>" data-action="keydown.esc@document->coplan--text-selection#dismiss" data-coplan--checkbox-revision-value="<%= @plan.current_revision %>" data-coplan--checkbox-toggle-url-value="<%= toggle_checkbox_plan_path(@plan) %>" data-coplan--changed-sections-keys-value="<%= @changed_section_keys.to_json %>">
        <nav class="content-nav" data-coplan--content-nav-target="sidebar" aria-label="Document outline">
          <div class="content-nav__header">
            <span class="content-nav__title">Contents</span>
            <button type="button" class="content-nav__toggle" data-action="coplan--content-nav#toggle" data-coplan--content-nav-target="toggleBtn" aria-label="Hide table of contents" title="Toggle (])">✕</button>
          </div>
          <ul class="content-nav__list" data-coplan--content-nav-target="list"></ul>
        </nav>
        <button type="button" class="content-nav-show-btn" data-action="coplan--content-nav#toggle" data-coplan--content-nav-target="showBtn" title="Show table of contents (])">☰ <kbd>]</kbd></button>

        <div class="plan-layout__content" data-coplan--text-selection-target="content" data-coplan--content-nav-target="content">
          <div id="plan-content-body"
               data-controller="coplan--live-update"
               data-coplan--live-update-revision-value="<%= @plan.current_revision %>">
            <%= render partial: "coplan/plans/content_body", locals: { plan: @plan } %>
          </div>

          <div class="comment-popover" data-coplan--text-selection-target="popover" style="display: none;">
            <button type="button" class="btn btn--primary btn--sm" data-action="coplan--text-selection#openCommentForm">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
              Comment
            </button>
          </div>

          <%= render partial: "coplan/comment_threads/new_comment_form", locals: { plan: @plan } %>
        </div>

        <div id="plan-threads" data-coplan--text-selection-target="threads"
             data-controller="coplan--viewer-role"
             data-coplan--viewer-role-viewer-id-value="<%= current_user&.id %>">
          <% @threads.select(&:anchored?).each do |thread| %>
            <%= render partial: "coplan/comment_threads/thread_popover", locals: { thread: thread, plan: @plan } %>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="empty-state">
        <p>This plan has no content yet.</p>
      </div>
    <% end %>
  </div>

  <div class="plan-tabs__panel card<%= ' plan-tabs__panel--hidden' unless active_tab == 'references' %>" id="tab-references" data-coplan--tabs-target="panel">
    <%= render partial: "coplan/plans/references", locals: { references: @references, plan: @plan } %>
  </div>

  <div class="plan-tabs__panel card<%= ' plan-tabs__panel--hidden' unless active_tab == 'attachments' %>" id="tab-attachments" data-coplan--tabs-target="panel">
    <%= render partial: "coplan/plans/attachments", locals: { attachments: @attachments, plan: @plan } %>
  </div>

  <div class="plan-tabs__panel card<%= ' plan-tabs__panel--hidden' unless active_tab == 'history' %>" id="tab-history" data-coplan--tabs-target="panel">
    <turbo-frame id="plan-history-frame" src="<%= history_plan_path(@plan) %>" loading="lazy">
      <div class="history-split__placeholder">
        <p class="text-muted">Loading…</p>
      </div>
    </turbo-frame>
  </div>
</div>

<%# Headless comment navigation — no floating toolbar, just the keyboard:
    j/k step through comments, r focuses reply, a/d accept/discard,
    s toggles resolved-thread visibility. %>
<% if @threads.any? %>
  <div data-controller="coplan--comment-nav" hidden></div>
<% end %>
