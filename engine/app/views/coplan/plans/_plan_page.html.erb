<%# One page of plan rows within a list (a folder/Unfiled group, or the
    flat ?filter= results list), plus the lazily-loaded next-page frame.
    `group_key` namespaces the frame ids so multiple groups can paginate
    independently on the same page; `frame_filter` is the workspace filter
    and `frame_folder` the folder scope the next-page request should carry
    (folder groups pass their root folder id here — the bare index URL has
    no folder param to inherit). %>
<%= turbo_frame_tag "plans-#{group_key}-page-#{page}" do %>
  <% plans.each do |plan| %>
    <%# suppress_folder_id: inside a folder group (or folder filter), a chip
        naming that same folder is noise — subfolder chips still show. %>
    <%= render "coplan/plans/plan_row", plan: plan, unread: plan_unread_counts[plan.id].to_i,
          suppress_folder_id: local_assigns[:frame_folder] %>
  <% end %>

  <% if has_next_page %>
    <% next_page = { page: page + 1, group: group_key, filter: frame_filter } %>
    <% next_page[:folder] = local_assigns[:frame_folder] if local_assigns[:frame_folder] %>
    <%= turbo_frame_tag "plans-#{group_key}-page-#{page + 1}",
          src: workspace_path(**next_page),
          loading: :lazy do %>
      <div class="plans-list__loading text-muted text-sm">Loading more plans…</div>
    <% end %>
  <% end %>
<% end %>
