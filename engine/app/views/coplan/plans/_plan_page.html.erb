<%# One page of plan rows within a list (a status group, or the flat
    ?status= results list), plus the lazily-loaded next-page frame.
    `group_key` namespaces the frame ids so multiple groups can paginate
    independently on the same page; `frame_status` is the status filter the
    next-page request should carry. %>
<%= turbo_frame_tag "plans-#{group_key}-page-#{page}" do %>
  <% plans.each do |plan| %>
    <%= render "coplan/plans/plan_row", plan: plan, unread: plan_unread_counts[plan.id].to_i %>
  <% end %>

  <% if has_next_page %>
    <% next_page_params = params.permit(:scope, :plan_type, :tag, :folder)
         .merge(page: page + 1, group: group_key, status: frame_status) %>
    <%= turbo_frame_tag "plans-#{group_key}-page-#{page + 1}",
          src: plans_path(next_page_params),
          loading: :lazy do %>
      <div class="plans-list__loading text-muted text-sm">Loading more plans…</div>
    <% end %>
  <% end %>
<% end %>
