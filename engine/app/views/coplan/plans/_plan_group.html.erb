<%# A collapsible main-pane group — one per root folder in the viewer's
    library (spanning its subtree), plus "Unfiled". Collapsed state persists
    per user in localStorage (coplan--plan-groups controller), keyed by
    data-group-key. The group body contains the first page of rows plus the
    lazy "load more" frame chain, so collapsing a group also stops further
    pages from loading. %>
<section class="plan-group"
         data-coplan--plan-groups-target="group"
         data-group-key="<%= group[:key] %>">
  <%# Group headings double as drop targets: drop a plan to file it in the
      group's root folder (or unshelve it, for Unfiled); drop a folder to
      nest it under the root (or promote it to top level). %>
  <h2 class="plan-group__heading"
      data-folder-id="<%= group[:folder]&.id %>"
      data-action="dragover->coplan--folder-dnd#dragOver dragleave->coplan--folder-dnd#dragLeave drop->coplan--folder-dnd#drop">
    <button type="button" class="plan-group__toggle" data-action="coplan--plan-groups#toggle"
            aria-expanded="true" aria-controls="plan-group-body-<%= group[:key] %>">
      <svg class="plan-group__chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <span class="plan-group__label">
        <% if group[:folder] %>
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg>
        <% end %>
        <%= group[:label] %>
      </span>
      <span class="plan-group__count">(<%= group[:count] %>)</span>
    </button>
    <% if group[:folder] %>
      <%= link_to workspace_path(filter: nil, folder: group[:folder].id),
            class: "plan-group__open", title: "Open #{group[:label]} as a filtered list" do %>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
      <% end %>
    <% end %>
  </h2>
  <div class="plan-group__body" id="plan-group-body-<%= group[:key] %>">
    <%= render "coplan/plans/plan_page", plans: group[:plans],
          plan_unread_counts: @plan_unread_counts,
          page: 1,
          has_next_page: group[:has_next_page],
          group_key: group[:key],
          frame_filter: nil,
          frame_folder: group[:folder]&.id %>
  </div>
</section>
