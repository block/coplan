<%# A collapsible group in the main pane (published work, or the viewer's
    private drafts). Collapsed state persists per user in localStorage
    (coplan--plan-groups controller); drafts start collapsed by default.
    The group body contains the first page of rows plus the lazy "load
    more" frame chain, so collapsing a group also stops further pages from
    loading. %>
<section class="plan-group"
         data-coplan--plan-groups-target="group"
         data-group-key="<%= group[:group] %>"
         <%= "data-default-collapsed".html_safe if group[:group] == "draft" %>>
  <h2 class="plan-group__heading">
    <button type="button" class="plan-group__toggle" data-action="coplan--plan-groups#toggle" aria-expanded="true">
      <svg class="plan-group__chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <span class="plan-group__label plan-group__label--<%= group[:group] %>"><%= group[:group] == "draft" ? "Drafts" : "Published" %></span>
      <span class="plan-group__count">(<%= group[:count] %>)</span>
    </button>
  </h2>
  <div class="plan-group__body" data-coplan--plan-groups-target="body">
    <%= render "coplan/plans/plan_page", plans: group[:plans],
          plan_unread_counts: @plan_unread_counts,
          page: 1,
          has_next_page: group[:has_next_page],
          group_key: group[:group],
          frame_filter: group[:group] %>
  </div>
</section>
