<% can_edit = current_user && CoPlan::PlanPolicy.new(current_user, plan).update? %>
<div class="attachments-section" id="plan-attachments">
  <% if can_edit %>
    <div class="attachments-section__header">
      <%# One designed dropzone instead of the native file input: click to
          browse or drag files on; choosing files uploads immediately. %>
      <%= form_with url: plan_attachments_path(plan), method: :post, multipart: true,
            class: "attachments-upload", data: { controller: "coplan--dropzone" } do |f| %>
        <button type="button" class="dropzone" data-coplan--dropzone-target="zone"
                data-action="click->coplan--dropzone#open dragover->coplan--dropzone#dragOver dragleave->coplan--dropzone#dragLeave drop->coplan--dropzone#drop">
          <svg class="dropzone__icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 14.899A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242"/><path d="M12 12v9"/><path d="m16 16-4-4-4 4"/></svg>
          <span class="dropzone__title" data-coplan--dropzone-target="label">Drop files here, or click to browse</span>
          <span class="dropzone__hint">Images, PDF, text, markdown, CSV, JSON, ZIP · up to <%= CoPlan::Plan::ATTACHMENT_MAX_BYTES / 1.megabyte %> MB each</span>
        </button>
        <%= f.file_field :files, multiple: true, name: "files[]", class: "dropzone__input",
              accept: CoPlan::Plan::ATTACHMENT_CONTENT_TYPES.join(","),
              data: { "coplan--dropzone-target": "input", action: "change->coplan--dropzone#changed" } %>
      <% end %>
    </div>
  <% end %>

  <% if attachments.any? %>
    <ul class="attachments-list">
      <% attachments.each do |attachment| %>
        <% blob = attachment.blob %>
        <% blob_path = main_app.rails_blob_path(blob) %>
        <% image = blob.content_type.to_s.start_with?("image/") %>
        <li class="attachments-list__item">
          <% if image %>
            <%# Plain <img> rather than a variant: variants require a system
                image processor (libvips/ImageMagick) that host apps can't be
                assumed to have. The browser downsizes via CSS. %>
            <a href="<%= blob_path %>" target="_blank" rel="noopener" class="attachments-list__thumb-link">
              <img src="<%= blob_path %>" alt="<%= blob.filename %>" class="attachments-list__thumb" loading="lazy">
            </a>
          <% else %>
            <span class="attachments-list__icon"><%= attachment_icon(blob.content_type) %></span>
          <% end %>
          <div class="attachments-list__content">
            <a href="<%= main_app.rails_blob_path(blob, disposition: :attachment) %>" class="attachments-list__link" download>
              <%= blob.filename %>
            </a>
            <span class="attachments-list__meta">
              <%= number_to_human_size(blob.byte_size) %>
              <% if (uploader = attachment_uploader_name(blob)) %>
                · uploaded by <%= uploader %>
              <% end %>
              · <%= time_ago_in_words(attachment.created_at) %> ago
            </span>
          </div>
          <span class="attachments-list__actions"
                data-controller="coplan--clipboard"
                data-coplan--clipboard-text-value="<%= attachment_markdown_snippet(blob, blob_path) %>">
            <button type="button" class="btn btn--secondary btn--sm" data-action="coplan--clipboard#copy"
                    data-coplan--clipboard-target="button" title="Copy markdown to embed this file in the plan">
              Copy markdown
            </button>
          </span>
          <% if can_edit %>
            <%= button_to "✕", plan_attachment_path(plan, attachment), method: :delete, class: "attachments-list__remove", title: "Delete attachment", data: { turbo_confirm: "Delete #{blob.filename}?" } %>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="empty-state">
      <p>No attachments yet.<% if can_edit %> Upload files to share diagrams, screenshots, or documents alongside the plan.<% end %></p>
    </div>
  <% end %>
</div>
