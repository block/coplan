<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "CoPlan" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= coplan_favicon_tag %>
    <%= yield :head %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "coplan/application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <nav class="site-nav">
      <div class="site-nav__inner">
        <%= link_to coplan.root_path, class: "site-nav__brand" do %>
          <%= image_tag "coplan/coplan-logo-sm.png", alt: "CoPlan", class: "site-nav__logo" %>
          CoPlan
          <%= coplan_environment_badge %>
        <% end %>
        <ul class="site-nav__links">
          <% if signed_in? %>
            <li><%= link_to "Plans", coplan.plans_path %></li>
            <li><%= link_to "Settings", coplan.settings_tokens_path %></li>
          <% end %>
        </ul>
        <% if signed_in? %>
          <div class="site-nav__right">
            <div class="inbox-dropdown" data-controller="coplan--inbox">
              <%= turbo_stream_from "coplan_notifications:#{current_user.id}" %>
              <button type="button" class="site-nav__bell" data-action="coplan--inbox#toggle" aria-label="Notifications">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                <% unread = current_user.notifications.unread.count %>
                <span id="inbox-badge" class="inbox-badge<%= ' inbox-badge--hidden' if unread == 0 %>" data-controller="coplan--inbox-badge"><%= unread %></span>
              </button>
              <div class="inbox-panel" data-coplan--inbox-target="panel" style="display: none;">
                <%= turbo_frame_tag "inbox-panel", src: coplan.notifications_path(panel: true), loading: :lazy do %>
                  <div class="inbox-panel__loading">Loading…</div>
                <% end %>
              </div>
            </div>
            <div class="site-nav__user">
              <span><%= current_user.name %></span>
              <% if main_app.respond_to?(:sign_out_path) %>
                <%= link_to "Sign out", main_app.sign_out_path, data: { turbo_method: :delete } %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </nav>
    <main class="main-content">
      <% if notice.present? %>
        <div class="flash flash--notice"><%= notice %></div>
      <% end %>
      <% if alert.present? %>
        <div class="flash flash--alert"><%= alert %></div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
