<% content_for(:title) { "Sign In — CoPlan" } %>

<div class="sign-in-page">
  <div class="sign-in-card card">
    <h1>CoPlan</h1>
    <p class="text-muted text-sm">Sign in with your work email</p>

    <div class="sign-in-warning">
      ⚠️ During initial development, login is a trust system. Use your <strong>ldap@squareup.com</strong> to sign in.
    </div>

    <%= form_with url: sign_in_path, method: :post, class: "sign-in-form" do |f| %>
      <div class="form-group">
        <%= f.label :email, "Email address" %>
        <%= f.email_field :email, autofocus: true, required: true, placeholder: "you@company.com" %>
      </div>

      <%= f.submit "Sign In", class: "btn btn--primary sign-in-submit" %>
    <% end %>
  </div>
</div>
